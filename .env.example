# Copy this file to .env and fill in your values
# NEVER commit .env to git

# LLM — OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_DEV_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_EVAL_MODEL=anthropic/claude-sonnet-4-6

# Email — Resend
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=outreach@yourdomain.com

# SMS — Africa's Talking
AFRICAS_TALKING_API_KEY=your_at_key_here
AFRICAS_TALKING_USERNAME=sandbox

# CRM — HubSpot Developer Sandbox
HUBSPOT_API_KEY=pat-na1-your_key_here

# Calendar — Cal.com
CALCOM_API_KEY=cal_live_your_key_here
CALCOM_EVENT_TYPE_ID=1

# Observability — Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Data paths
CRUNCHBASE_CSV=data/crunchbase_data.csv
LAYOFFS_CSV=data/layoffs.csv

# Safety kill-switch — set to false to prevent any live outbound emails
# When false, all emails go to SINK_EMAIL instead of the real prospect
OUTBOUND_ENABLED=false
SINK_EMAIL=your.test.email@gmail.com
